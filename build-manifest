#!/usr/bin/env python3
"""Build icon manifest from local SVG files using selfhst metadata."""
import json, os
from pathlib import Path
here = Path(__file__).parent.resolve()
icons_dir = here / "icons"
meta_file = here / "icons" / "selfhst-index.json"
# Load selfhst metadata if available
meta = {}
if meta_file.exists():
    try:
        with open(meta_file) as f: data = json.load(f)
        for item in data:
            ref = item.get("Reference", "").strip().lower()
            if ref: meta[ref] = item
    except: pass
manifest = []
for f in sorted(icons_dir.glob("*.svg")):
    name = f.stem
    item = meta.get(name, {})
    title = item.get("Name", "") or " ".join(w.capitalize() for w in name.replace("-", " ").split())
    tags = []
    if item.get("Tags"):
        tags = [t.strip() for t in item["Tags"].split(",") if t.strip()]
    if item.get("Category"):
        cats = [c.strip() for c in item["Category"].split(",") if c.strip()]
        tags.extend(cats)
    manifest.append({"name": title, "file": name, "format": "svg", "tags": list(set(tags))})
out = icons_dir / "manifest.json"
with open(out, "w") as f:
    json.dump(manifest, f, indent=2)
print(f"Manifest: {len(manifest)} icons to {out}")
