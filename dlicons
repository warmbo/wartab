#!/usr/bin/env python3
"""Batch download all selfhst SVG icons + metadata to /icons/."""
import json, os, sys, time, urllib.request, urllib.error
from pathlib import Path
HERE = Path(__file__).parent.resolve()
ICONS = HERE / "icons"
ICONS.mkdir(exist_ok=True)
MANIFEST_URL = "https://raw.githubusercontent.com/selfhst/icons/main/index.json"
CDN_BASE = "https://cdn.jsdelivr.net/gh/selfhst/icons@main/svg"
# Download index.json first
idx_path = ICONS / "selfhst-index.json"
if not idx_path.exists():
    print("Downloading icon index...")
    try:
        req = urllib.request.Request(MANIFEST_URL, headers={"User-Agent": "WarTab/1.0"})
        with urllib.request.urlopen(req, timeout=60) as resp:
            data = json.loads(resp.read())
        with open(idx_path, "w") as f:
            json.dump(data, f)
        print(f"Index saved: {len(data)} entries")
    except Exception as e:
        print(f"Failed to download index: {e}")
        sys.exit(1)
else:
    with open(idx_path) as f:
        data = json.load(f)
    print(f"Using cached index: {len(data)} entries")
# Filter to SVG
svgs = [item for item in data if item.get("SVG") == "Yes"]
print(f"{len(svgs)} icons with SVG")
downloaded = 0; skipped = 0; failed = 0
for item in svgs:
    ref = item.get("Reference", "").strip()
    if not ref: skipped += 1; continue
    safe = "".join(c for c in ref if c.isalnum() or c in "-_.").lower()
    if not safe: skipped += 1; continue
    safe = safe.rstrip(".") + ".svg"
    out_path = ICONS / safe
    if out_path.exists(): skipped += 1; continue
    try:
        req2 = urllib.request.Request(f"{CDN_BASE}/{ref}.svg", headers={"User-Agent": "WarTab/1.0"})
        with urllib.request.urlopen(req2, timeout=15) as r:
            with open(out_path, "wb") as f: f.write(r.read())
        downloaded += 1
        if downloaded % 100 == 0: print(f"  {downloaded} downloaded ({skipped} skipped)")
    except: failed += 1
    time.sleep(0.05)
print(f"\nDone! {downloaded} new, {skipped} cached, {failed} failed")
