{
  "version": "0.2.1",
  "branding": {
    "title": "WarTab",
    "icon": "sword"
  },
  "theme": {
    "bgType": "gradient",
    "bgValue": "#0a0a0a, #1a1a1a, #0d0d0d",
    "blur": 20,
    "glow": "#888888",
    "fontSize": "medium",
    "fontFamily": "Inter",
    "cardBg": "dark",
    "fontColor": "#cccccc",
