    "items": [
      "cpu",
      "memory",
      "disk",
      "uptime"
    ],
    "hostname": true
  },
  "layout": {
    "cols": 4,
    "gap": 16,
    "pageWidth": "full",
    "paddingHeight": "full"
  },
  "search": {
    "engine": "https://www.google.com/search?q=",
