{
  "manifest_version": 3,
  "name": "WarTab",
  "version": "0.2.1",
  "description": "A self-hosted new tab dashboard with glassmorphic styling — cards, widgets, pages, and full customization.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "system.cpu",
    "system.memory",
    "system.storage"
  ],
  "icons": {
    "16": "icons/extension-16.png",
    "48": "icons/extension-48.png",
    "128": "icons/extension-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "static/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
